---
import '../styles/global.css'
import Layout from '../layouts/Layout.astro';
import { getCollection } from "astro:content";
import ProjectCoverCard from "../components/ProjectCoverCard.astro";

const projects = await getCollection("projects");
const EMAIL = "frankvillarredondo@gmail.com";
const GMAIL_COMPOSE = `https://mail.google.com/mail/?view=cm&fs=1&to=${EMAIL}&su=${encodeURIComponent("Contacto desde portfolio")}`;

// Ordenar por fecha desc si existe
projects.sort((a, b) => {
  const ad = a.data.date ? a.data.date.getTime() : 0;
  const bd = b.data.date ? b.data.date.getTime() : 0;
  return bd - ad;
});
---

<Layout title="Proyectos | Frank Villar">
	<header data-animate-load class="fixed top-0 w-full backdrop-blur-md bg-neutral-950/90 border-b border-neutral-800 z-50">
		<nav aria-label="Principal" class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
			<a href="/" class="font-mono text-xl font-bold tracking-tighter text-white hover:text-amber-400 transition">
				&lt;frank /&gt;
			</a>
			<div class="hidden sm:flex gap-6 text-sm font-mono text-slate-400">
				<a href="#skills" class="nav-link hover:text-amber-400 transition">/skills</a>
				<a href="#proyectos" class="nav-link hover:text-amber-400 transition">/proyectos</a>
				<a href="#experiencia" class="nav-link hover:text-amber-400 transition">/experiencia</a>
				<a href="#contacto" class="nav-link hover:text-amber-400 transition">/contacto</a>
			</div>
			<!-- Mobile menu button -->
			<button
				id="menu-btn"
				type="button"
				class="sm:hidden text-slate-400 hover:text-amber-400 transition"
				aria-label="Abrir menú de navegación"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</nav>
		<!-- Mobile menu -->
		<div id="mobile-menu" class="hidden sm:hidden border-t border-neutral-800 bg-neutral-950/95 backdrop-blur-md" hidden>
			<div class="flex flex-col gap-4 px-6 py-5 text-sm font-mono text-slate-400">
				<a href="#skills" class="nav-link hover:text-amber-400 transition">/skills</a>
				<a href="#proyectos" class="nav-link hover:text-amber-400 transition">/proyectos</a>
				<a href="#experiencia" class="nav-link hover:text-amber-400 transition">/experiencia</a>
				<a href="#contacto" class="nav-link hover:text-amber-400 transition">/contacto</a>
			</div>
		</div>
	</header>

	<main class="max-w-4xl mx-auto px-6 pt-32 pb-20">
		<div data-animate-stagger class="mb-12 flex flex-col">
			<a href="/" class="inline-flex items-center gap-2 text-sm font-mono text-slate-400 hover:text-amber-400 transition mb-6 w-fit">
				<span>← volver_a_inicio</span>
			</a>
			
			<h1 class="text-4xl font-bold tracking-tight mb-4 leading-tight text-white">
				Todos mis <span class="bg-gradient-to-r from-amber-300 via-yellow-300 to-amber-400 bg-clip-text text-transparent text-shimmer">Proyectos</span>
			</h1>
			<p class="text-slate-400 text-lg max-w-2xl leading-relaxed">
				Una lista completa de los proyectos que he desarrollado, que abarcan desde automatizaciones backend y diseño de APIs hasta interfaces de usuario completas.
			</p>
		</div>

		{/* Grid de Proyectos */}
		<section class="py-6 border-t border-neutral-900">
			<div data-animate-stagger class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{projects.map((p) => <ProjectCoverCard project={p} />)}
			</div>
		</section>

		<!-- Botón de Contacto (coherencia con footer/contacto de la home) -->
		<section data-animate class="py-16 mt-16 border-t border-neutral-900 text-center">
			<h2 class="text-2xl font-bold mb-4 text-white">¿Te interesa algún proyecto?</h2>
			<p class="text-slate-400 max-w-md mx-auto mb-8 text-sm">
				Si quieres saber más sobre la arquitectura o implementación de alguno de ellos, no dudes en escribirme.
			</p>
			<a
				href={GMAIL_COMPOSE}
				target="_blank"
				rel="noopener noreferrer"
				aria-label={`Escribir a ${EMAIL} en Gmail`}
				class="inline-flex items-center justify-center gap-3 px-8 py-3.5 bg-amber-400 hover:bg-yellow-300 text-neutral-950 font-mono font-semibold rounded-xl transition-all shadow-lg shadow-amber-500/25 motion-safe-active-scale"
			>
				<span>enviar_email()</span>
			</a>
		</section>
	</main>

	<footer class="border-t border-neutral-800 py-10 text-center text-xs font-mono text-neutral-500">
		<p>Frank Villar · Hecho con Astro & Tailwind · {new Date().getFullYear()}</p>
	</footer>
</Layout>

<script>
	const btn = document.getElementById('menu-btn');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
	
	// Cerrar menú al hacer click en un enlace
	menu?.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', () => menu?.classList.add('hidden'));
	});
</script>
