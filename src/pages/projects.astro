---
import '../styles/global.css'
import Layout from '../layouts/Layout.astro';
import { getCollection } from "astro:content";
import ProjectCoverCard from "../components/ProjectCoverCard.astro";

const projects = await getCollection("projects");
const EMAIL = "frankvillarredondo@gmail.com";
const GMAIL_COMPOSE = `https://mail.google.com/mail/?view=cm&fs=1&to=${EMAIL}&su=${encodeURIComponent("Contacto desde portfolio")}`;

// Ordenar por fecha desc si existe
projects.sort((a, b) => {
  const ad = a.data.date ? a.data.date.getTime() : 0;
  const bd = b.data.date ? b.data.date.getTime() : 0;
  return bd - ad;
});
---

<Layout title="Proyectos | Frank Villar" nav="projects">
	<main class="max-w-4xl mx-auto px-6 pt-32 pb-20">
		<div data-animate-stagger class="mb-12 flex flex-col">
			<h1 class="text-4xl font-bold tracking-tight mb-4 leading-tight text-white">
				Todos mis <span class="bg-gradient-to-r from-amber-300 via-yellow-300 to-amber-400 bg-clip-text text-transparent text-shimmer">Proyectos</span>
			</h1>
			<p class="text-slate-400 text-lg max-w-2xl leading-relaxed">
				Una lista completa de los proyectos que he desarrollado, que abarcan desde automatizaciones backend y diseño de APIs hasta interfaces de usuario completas.
			</p>
		</div>

		{/* Grid de Proyectos */}
		<section class="py-6 border-t border-neutral-900">
			<div data-animate-stagger class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{projects.map((p) => <ProjectCoverCard project={p} from="projects" />)}
			</div>
		</section>

		<!-- Botón de Contacto (coherencia con footer/contacto de la home) -->
		<section data-animate class="py-16 mt-16 border-t border-neutral-900 text-center">
			<h2 class="text-2xl font-bold mb-4 text-white">¿Te interesa algún proyecto?</h2>
			<p class="text-slate-400 max-w-md mx-auto mb-8 text-sm">
				Si quieres saber más sobre la arquitectura o implementación de alguno de ellos, no dudes en escribirme.
			</p>
			<a
				href={GMAIL_COMPOSE}
				target="_blank"
				rel="noopener noreferrer"
				aria-label={`Escribir a ${EMAIL} en Gmail`}
				class="inline-flex items-center justify-center gap-3 px-8 py-3.5 bg-amber-400 hover:bg-yellow-300 text-neutral-950 font-mono font-semibold rounded-xl transition-all shadow-lg shadow-amber-500/25 motion-safe-active-scale"
			>
				<span>Enviar correo</span>
			</a>
		</section>
	</main>

	<footer class="border-t border-neutral-800 py-10 text-center text-xs font-mono text-neutral-400">
		<p>Frank Villar · Hecho con Astro & Tailwind · {new Date().getFullYear()}</p>
	</footer>
</Layout>

