---
import MotionInit from "../components/MotionInit.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Frank Villar — Desarrollador backend y automatización. Portfolio DAW con proyectos en Python, Django, React y Next.js." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="bg-neutral-950 text-slate-100 font-sans min-h-screen selection:bg-amber-400 selection:text-neutral-950">
		<div class="pointer-events-none fixed inset-0 z-[-2] overflow-hidden" aria-hidden="true">
			<div class="absolute top-0 h-screen w-screen bg-neutral-950 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(245,158,11,0.18),rgba(255,255,255,0))]"></div>
			<div class="animate-glow-drift absolute -top-32 left-1/4 h-96 w-96 rounded-full bg-amber-500/10 blur-3xl"></div>
			<div class="animate-glow-drift absolute top-1/3 -right-20 h-80 w-80 rounded-full bg-yellow-400/5 blur-3xl" style="animation-delay: -5s"></div>
		</div>
		<slot />
		<MotionInit />
	</body>
</html>