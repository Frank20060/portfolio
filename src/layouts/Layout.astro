---
import MotionInit from "../components/MotionInit.astro";
import PrefetchLinks from "../components/PrefetchLinks.astro";
import SiteHeader, { type NavVariant } from "../components/SiteHeader.astro";
import type { ProjectLinkFrom } from "../lib/projectLinks";

interface Props {
	title: string;
	nav?: NavVariant;
	backFrom?: ProjectLinkFrom;
	pageTitle?: string;
	description?: string;
}

const { title, nav = "home", backFrom = "projects", pageTitle, description } = Astro.props;

const siteUrl = Astro.site ?? "https://frank-villar-redondo.vercel.app";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const metaDescription =
	description ??
	"Frank Villar — Desarrollador backend y automatización. Portfolio DAW con proyectos en Python, Django, React y Next.js.";
const ogTitle = title;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
		<meta name="description" content={metaDescription} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:site_name" content="Frank Villar — Portfolio" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={metaDescription} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
				rel="stylesheet"
			/>
		</noscript>
	</head>
	<body class="bg-neutral-950 text-slate-100 font-sans min-h-screen selection:bg-amber-400 selection:text-neutral-950">
		<div class="pointer-events-none fixed inset-0 z-[-2] overflow-hidden" aria-hidden="true">
			<div class="absolute top-0 h-screen w-screen bg-neutral-950 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(245,158,11,0.18),rgba(255,255,255,0))]"></div>
			<div class="animate-glow-drift absolute -top-32 left-1/4 h-96 w-96 rounded-full bg-amber-500/10 blur-3xl"></div>
			<div class="animate-glow-drift absolute top-1/3 -right-20 h-80 w-80 rounded-full bg-yellow-400/5 blur-3xl" style="animation-delay: -5s"></div>
		</div>
		<a
			href="#contenido"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:px-4 focus:py-2 focus:bg-amber-400 focus:text-neutral-950 focus:rounded-lg focus:font-mono focus:text-sm"
		>
			Saltar al contenido
		</a>
		<SiteHeader variant={nav} backFrom={backFrom} pageTitle={pageTitle} />
		<div id="contenido">
			<slot />
		</div>
		<MotionInit />
		<PrefetchLinks />
	</body>
</html>
