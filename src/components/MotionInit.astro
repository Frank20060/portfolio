<script>
  const revealAll = () => {
    document.querySelectorAll("[data-animate], [data-animate-stagger], [data-animate-load]").forEach((el) => {
      el.classList.add("is-visible");
    });
  };

  const resetMotion = () => {
    document.querySelectorAll("[data-animate], [data-animate-stagger], [data-animate-load]").forEach((el) => {
      el.classList.remove("is-visible");
    });
  };

  const initMotion = () => {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      revealAll();
      return;
    }

    document.querySelectorAll("[data-animate-load]").forEach((el) => {
      el.classList.add("is-visible");
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.08, rootMargin: "0px 0px -4% 0px" }
    );

    document.querySelectorAll("[data-animate], [data-animate-stagger]").forEach((el) => {
      observer.observe(el);
    });
  };

  const run = () => {
    resetMotion();
    initMotion();
  };

  run();
  document.addEventListener("astro:page-load", run);
</script>
