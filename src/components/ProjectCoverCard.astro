---
import type { CollectionEntry } from "astro:content";
import { projectDetailHref, type ProjectLinkFrom } from "../lib/projectLinks";
import ProjectCoverImage from "./ProjectCoverImage.astro";

type Props = {
  project: CollectionEntry<"projects">;
  from?: ProjectLinkFrom;
};

const { project, from = "projects" } = Astro.props;
const { title, description, tech, cover, company, role, date, coverFit = "cover", coverBg } = project.data;
const href = projectDetailHref(project.id, from);
const imgFit = coverFit === "contain" ? "object-contain p-5 sm:p-8" : "object-cover motion-safe-img-zoom";
const coverStyle = coverBg ? `background-color: ${coverBg}` : undefined;

const fallbackGradients = [
  "from-amber-500/15 via-neutral-900 to-neutral-950",
  "from-yellow-600/10 via-neutral-900 to-neutral-950",
  "from-orange-500/10 via-neutral-900 to-neutral-950",
];
const selectedGradient = fallbackGradients[title.length % fallbackGradients.length];

const when = date
  ? new Intl.DateTimeFormat("es-ES", { year: "numeric", month: "short" }).format(date)
  : null;
---

<article
  class="group relative flex flex-col rounded-2xl overflow-hidden border border-neutral-800 bg-neutral-900/50 transition-all duration-300 motion-safe-hover-lift hover:border-amber-400/40 hover:shadow-2xl hover:shadow-amber-500/10"
>
  <div
    class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-amber-400/0 via-amber-400/0 to-amber-400/0 group-hover:from-amber-400 group-hover:via-amber-400/60 group-hover:to-amber-400/20 transition-all duration-300 z-20 pointer-events-none"
    aria-hidden="true"
  ></div>

  <a
    href={href}
    class="flex flex-col flex-1 text-inherit no-underline focus-visible:rounded-2xl"
  >
    <span class="block relative aspect-[16/10] overflow-hidden border-b border-neutral-800/80">
      {cover ? (
        <span class="block w-full h-full relative" style={coverStyle}>
          <ProjectCoverImage
            cover={cover}
            title={title}
            class={`w-full h-full transition-transform duration-500 ${imgFit}`}
            loading="lazy"
            widths={[400, 640]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </span>
      ) : (
        <span class={`block w-full h-full flex flex-col items-center justify-center bg-gradient-to-br ${selectedGradient} relative`}>
          <span class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:20px_20px]" aria-hidden="true"></span>
          <span class="font-mono text-5xl font-extrabold text-amber-400/20 select-none tracking-widest" aria-hidden="true">{title.slice(0, 2).toUpperCase()}</span>
        </span>
      )}

      <span class="absolute inset-0 bg-gradient-to-t from-neutral-950/90 via-transparent to-amber-400/5 opacity-80 group-hover:opacity-100 transition-opacity pointer-events-none" aria-hidden="true"></span>

      {company && (
        <span class="absolute top-3 left-3 z-10 max-w-[85%] truncate px-2.5 py-1 text-xs font-mono font-semibold tracking-wider uppercase bg-neutral-950/85 text-amber-300 rounded-md border border-amber-400/25 backdrop-blur-sm">
          {company}
        </span>
      )}

      {when && (
        <span class="absolute top-3 right-3 z-10 px-2 py-0.5 text-xs font-mono text-slate-300 bg-neutral-950/80 rounded-md border border-neutral-700 backdrop-blur-sm">
          {when}
        </span>
      )}
    </span>

    <span class="relative p-5 sm:p-6 flex flex-col flex-1 bg-gradient-to-b from-neutral-900/80 to-neutral-950/90">
      <span class="absolute inset-0 opacity-[0.03] bg-[linear-gradient(to_right,#fff_1px,transparent_1px),linear-gradient(to_bottom,#fff_1px,transparent_1px)] bg-[size:16px_16px] pointer-events-none" aria-hidden="true"></span>

      <span class="relative mb-4 block">
        {role && <span class="block text-xs font-mono text-amber-300 mb-1.5 tracking-wide">{role}</span>}
        <h3 class="text-lg sm:text-xl font-bold text-white group-hover:text-amber-200 transition leading-snug pr-6">
          {title}
        </h3>
        <p class="text-slate-400 text-sm mt-2.5 leading-relaxed line-clamp-2">
          {description}
        </p>
      </span>

      <span class="relative mt-auto pt-4 border-t border-neutral-800/90 space-y-4 block">
        <span class="flex flex-wrap gap-1.5 min-h-[1.75rem]" aria-hidden="true">
          {tech?.slice(0, 5).map((t) => (
            <span class="text-xs font-mono px-2 py-0.5 rounded-md bg-neutral-950 text-slate-300 border border-neutral-800 group-hover:border-amber-900/50 group-hover:text-amber-200/80 transition-colors">
              {t}
            </span>
          ))}
          {tech && tech.length > 5 && (
            <span class="text-xs font-mono px-2 py-0.5 text-slate-300">+{tech.length - 5}</span>
          )}
        </span>

        <span class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-neutral-700 bg-neutral-950 py-2.5 text-sm font-medium text-slate-200 transition-all duration-300 group-hover:border-amber-400 group-hover:bg-amber-400 group-hover:text-neutral-950 group-hover:shadow-md group-hover:shadow-amber-500/20 motion-safe-active-scale">
          Ver proyecto
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform duration-300 group-hover:translate-x-0.5"
            aria-hidden="true"
          >
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </span>
      </span>
    </span>
  </a>
</article>
