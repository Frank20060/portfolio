---
import { Image } from "astro:assets";
import { resolveCover } from "../lib/covers";

interface Props {
  cover?: string;
  title: string;
  class?: string;
  loading?: "lazy" | "eager";
  widths?: number[];
  sizes?: string;
}

const {
  cover,
  title,
  class: className = "w-full h-full",
  loading = "lazy",
  widths = [400, 640, 960],
  sizes = "(max-width: 768px) 100vw, 50vw",
} = Astro.props;

const src = resolveCover(cover);
---

{
  src && (
    <Image
      src={src}
      alt={`Portada de ${title}`}
      widths={widths}
      sizes={sizes}
      loading={loading}
      decoding="async"
      class={className}
    />
  )
}
