---
import type { CollectionEntry } from "astro:content";

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props;
const { title, description, tech } = project.data;
const href = `/projects/${project.id}`;
---

<a
  href={href}
  class="group bg-neutral-900 border border-neutral-800 hover:border-amber-400/60 rounded-2xl p-7 transition-all duration-300 flex flex-col justify-between hover:-translate-y-0.5"
>
  <div>
    <h3 class="text-xl font-semibold mb-3 text-white group-hover:text-amber-300 transition">
      {title}
    </h3>
    <p class="text-slate-400 text-[15px] leading-relaxed mb-6">
      {description}
    </p>
  </div>

  <div>
    <div class="flex flex-wrap gap-2">
      {tech?.slice(0, 6).map((t) => (
        <span class="text-xs font-mono px-3 py-1.5 bg-neutral-950 text-amber-400/90 rounded-lg border border-neutral-700">
          {t}
        </span>
      ))}
      {tech && tech.length > 6 && (
        <span class="text-xs font-mono px-3 py-1.5 bg-neutral-950 text-slate-400 rounded-lg border border-neutral-700">
          +{tech.length - 6}
        </span>
      )}
    </div>

    <div class="mt-6 text-sm font-mono text-slate-400 border-t border-neutral-800 pt-5">
      <span class="group-hover:text-amber-400 transition">ver_detalles →</span>
    </div>
  </div>
</a>