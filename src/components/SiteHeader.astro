---
import { backLinkFor, type ProjectLinkFrom } from "../lib/projectLinks"

export type NavVariant = "home" | "projects" | "project"

interface Props {
  variant?: NavVariant
  backFrom?: ProjectLinkFrom
  pageTitle?: string
}

const { variant = "home", backFrom = "projects", pageTitle } = Astro.props

const isHome = variant === "home"
const isProjectsList = variant === "projects"
const isProject = variant === "project"

const back = isProjectsList
  ? backLinkFor("home")
  : backLinkFor(backFrom)

const navSections = [
  { id: "skills", label: "/stack", ariaLabel: "Ir a stack técnico" },
  { id: "proyectos", label: "/proyectos", ariaLabel: "Ir a proyectos destacados" },
  { id: "experiencia", label: "/experiencia", ariaLabel: "Ir a experiencia laboral" },
  { id: "sobre-mi", label: "/sobre_mi", ariaLabel: "Ir a sobre mí" },
  { id: "contacto", label: "/contacto", ariaLabel: "Ir a contacto" },
] as const

const backBtnClass =
  "inline-flex items-center gap-2 text-sm font-mono text-slate-400 hover:text-amber-400 transition border border-neutral-800 hover:border-amber-400/40 bg-neutral-900/50 hover:bg-neutral-900 rounded-xl px-4 py-2 motion-safe-active-scale shrink-0"
---

<header data-animate-load class="fixed top-0 w-full backdrop-blur-md bg-neutral-950/90 border-b border-neutral-800 z-50">
  <nav
    aria-label="Principal"
    class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between gap-4"
    data-nav-variant={variant}
  >
    <a href="/" class="font-mono text-xl font-bold tracking-tighter text-white hover:text-amber-400 transition shrink-0">
      &lt;frank /&gt;
    </a>

    {
      isHome ? (
        <>
          <div class="hidden sm:flex gap-6 text-sm font-mono">
            {navSections.map(({ id, label, ariaLabel }) => (
              <a
                href={`#${id}`}
                data-nav-section={id}
                aria-label={ariaLabel}
                class="nav-link text-slate-400 hover:text-amber-400 transition"
              >
                {label}
              </a>
            ))}
          </div>
          <button
            id="menu-btn"
            type="button"
            class="sm:hidden text-slate-400 hover:text-amber-400 transition shrink-0"
            aria-label="Abrir menú de navegación"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </>
      ) : (
        <div class="flex items-center gap-3 min-w-0 flex-1 justify-end">
          {isProject && pageTitle && (
            <p class="hidden sm:block text-sm font-medium text-slate-300 truncate max-w-[min(40vw,280px)] text-right mr-1" title={pageTitle}>
              {pageTitle}
            </p>
          )}
          <a
            href={back.href}
            class={backBtnClass}
            data-back-link={isProject ? true : undefined}
            aria-label={back.ariaLabel}
          >
            <span aria-hidden="true">←</span>
            <span data-back-label>{back.label}</span>
          </a>
        </div>
      )
    }
  </nav>

  {
    isHome && (
      <div id="mobile-menu" class="hidden sm:hidden border-t border-neutral-800 bg-neutral-950/95 backdrop-blur-md" hidden aria-hidden="true">
        <div class="flex flex-col gap-4 px-6 py-5 text-sm font-mono text-slate-400">
          {navSections.map(({ id, label, ariaLabel }) => (
            <a
              href={`#${id}`}
              data-nav-section={id}
              aria-label={ariaLabel}
              class="nav-link hover:text-amber-400 transition text-slate-400"
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    )
  }
</header>

<script>
  const bindMenu = () => {
    const btn = document.getElementById("menu-btn")
    const menu = document.getElementById("mobile-menu")
    if (!btn || !menu || btn.dataset.menuBound) return
    btn.dataset.menuBound = "true"

    const setMenuOpen = (open) => {
      btn.setAttribute("aria-expanded", String(open))
      btn.setAttribute("aria-label", open ? "Cerrar menú de navegación" : "Abrir menú de navegación")
      menu.classList.toggle("hidden", !open)
      menu.hidden = !open
      menu.setAttribute("aria-hidden", String(!open))

      if (open) {
        const firstLink = menu.querySelector("a")
        firstLink?.focus()
      } else {
        btn.focus()
      }
    }

    btn.addEventListener("click", () => {
      const willOpen = btn.getAttribute("aria-expanded") !== "true"
      setMenuOpen(willOpen)
    })

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        setMenuOpen(false)
      })
    })

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && btn.getAttribute("aria-expanded") === "true") {
        setMenuOpen(false)
        btn.focus()
      }
    })
  }

  const NAV_SECTION_IDS = ["skills", "proyectos", "experiencia", "sobre-mi", "contacto"]
  const HEADER_OFFSET = 96
  const TOP_BUFFER = 48
  /** Línea de lectura (~30 % del viewport bajo el header) para activar sección */
  const activationDocY = () =>
    window.scrollY + HEADER_OFFSET + window.innerHeight * 0.3

  const setActiveNav = (sectionId) => {
    document.querySelectorAll("[data-nav-section]").forEach((link) => {
      const active = Boolean(sectionId) && link.getAttribute("data-nav-section") === sectionId
      link.classList.toggle("nav-link--active", active)
      link.classList.toggle("text-amber-400", active)
      link.classList.toggle("text-slate-400", !active)
      if (active) link.setAttribute("aria-current", "location")
      else link.removeAttribute("aria-current")
    })
  }

  /**
   * Activa la sección que contiene la línea de lectura (no la de mayor área visible).
   * Al final de página fuerza contacto: la línea suele quedar en el footer, no en #contacto.
   */
  const pickActiveSection = (sections) => {
    if (!sections.length) return null

    const scrollY = window.scrollY
    const firstSection = sections[0]
    if (scrollY < firstSection.offsetTop - HEADER_OFFSET - TOP_BUFFER) {
      return null
    }

    const lastSection = sections[sections.length - 1]
    const distanceFromBottom =
      document.documentElement.scrollHeight - (scrollY + window.innerHeight)

    if (distanceFromBottom < 160) {
      return lastSection.id
    }

    const line = activationDocY()
    const lastEnd = lastSection.offsetTop + lastSection.offsetHeight

    if (line >= lastEnd - 48) {
      return lastSection.id
    }

    if (lastSection.id === "contacto") {
      const { top: contactTop } = lastSection.getBoundingClientRect()
      if (contactTop <= window.innerHeight * 0.45) {
        return "contacto"
      }
    }

    for (const section of sections) {
      const start = section.offsetTop
      const end = start + section.offsetHeight
      if (start <= line && end > line) return section.id
    }

    let current = null
    for (const section of sections) {
      if (section.offsetTop <= line) current = section.id
    }
    return current
  }

  const initNavSpy = () => {
    const nav = document.querySelector('[data-nav-variant="home"]')
    if (!nav) return

    const sections = NAV_SECTION_IDS.map((id) => document.getElementById(id)).filter(Boolean)
    if (!sections.length) return

    let navSpyPaused = false
    let pauseCleanup = null

    const update = () => {
      if (navSpyPaused) return
      setActiveNav(pickActiveSection(sections))
    }

    const resumeNavSpy = () => {
      if (pauseCleanup) {
        pauseCleanup()
        pauseCleanup = null
      }
      navSpyPaused = false
      update()
    }

    const pauseNavSpyForScroll = (sectionId) => {
      if (pauseCleanup) pauseCleanup()
      navSpyPaused = true
      setActiveNav(sectionId)

      let scrollSettleTimer
      let maxTimer

      const cleanup = () => {
        window.removeEventListener("scroll", onScrollWhilePaused)
        window.removeEventListener("scrollend", onScrollEnd)
        clearTimeout(scrollSettleTimer)
        clearTimeout(maxTimer)
        pauseCleanup = null
      }

      const onScrollEnd = () => {
        cleanup()
        resumeNavSpy()
      }

      const onScrollWhilePaused = () => {
        clearTimeout(scrollSettleTimer)
        scrollSettleTimer = setTimeout(() => {
          cleanup()
          resumeNavSpy()
        }, 140)
      }

      window.addEventListener("scroll", onScrollWhilePaused, { passive: true })
      if ("onscrollend" in window) {
        window.addEventListener("scrollend", onScrollEnd, { once: true })
      }

      maxTimer = setTimeout(() => {
        cleanup()
        resumeNavSpy()
      }, 2200)

      pauseCleanup = cleanup
      onScrollWhilePaused()
    }

    const hash = location.hash.replace("#", "")
    if (NAV_SECTION_IDS.includes(hash)) {
      setActiveNav(hash)
    } else {
      update()
    }

    let ticking = false
    const onScroll = () => {
      if (navSpyPaused || ticking) return
      ticking = true
      requestAnimationFrame(() => {
        update()
        ticking = false
      })
    }

    window.addEventListener("scroll", onScroll, { passive: true })
    window.addEventListener("hashchange", () => {
      if (!navSpyPaused) update()
    })

    const header = nav.closest("header")
    header?.querySelectorAll("[data-nav-section]").forEach((link) => {
      link.addEventListener("click", () => {
        const id = link.getAttribute("data-nav-section")
        if (id) pauseNavSpyForScroll(id)
      })
    })
  }

  const initProjectBackLink = () => {
    const link = document.querySelector("[data-back-link]")
    if (!link) return

    const labelEl = link.querySelector("[data-back-label]")
    const fromHome = new URLSearchParams(window.location.search).get("from") === "home"
    const href = fromHome ? "/#proyectos" : "/projects"
    const label = fromHome ? "Volver al inicio" : "Volver a proyectos"
    const ariaLabel = fromHome ? "Volver a la sección de proyectos en el inicio" : "Volver a la lista de proyectos"

    link.setAttribute("href", href)
    link.setAttribute("aria-label", ariaLabel)
    if (labelEl) labelEl.textContent = label
  }

  bindMenu()
  initNavSpy()
  initProjectBackLink()
</script>
